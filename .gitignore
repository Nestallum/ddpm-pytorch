# -----------------------------------------------------------------------------
# Project-specific: data, checkpoints, logs, generated samples
# -----------------------------------------------------------------------------

# Raw datasets (downloaded by torchvision)
/data/
/notebooks/data/

# Model weights, EMA snapshots
checkpoints/

# TensorBoard logs
runs/

# Text logs
logs/

# Generated samples, FID statistics
outputs/

# Weights & Biases (if added later)
wandb/

# Pretrained model caches downloaded by torchmetrics / torch-fidelity
/*.pt

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
.env
.env.local