# but ignore the cache
.uv-cache/

# -----------------------------------------------------------------------------
# IDE / Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Project-specific: data, checkpoints, logs, generated samples
# -----------------------------------------------------------------------------
data/                # raw datasets (FashionMNIST, CIFAR-10, ...)
**/data/
checkpoints/         # model weights, EMA snapshots
runs/                # TensorBoard logs
logs/                # text logs
outputs/             # generated samples, FID statistics
wandb/               # (if W&B is added later)

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
.env
.env.local